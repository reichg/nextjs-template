// Prisma schema for the full-stack template.
// `Item` is a neutral example model — replace or delete it for your domain.
// Prisma 7 no longer carries the connection URL in the datasource block: the
// runtime connection comes from the PrismaPg driver adapter (see
// src/server/db/prisma.ts) and Migrate reads it from prisma.config.ts.

// The `prisma-client-js` generator emits the client into a repo-root
// `generated/prisma` directory (via the `output` path below). Consumers import
// `PrismaClient` from that generated path (e.g. src/server/db/prisma.ts and
// prisma/seed.ts) instead of the bare `@prisma/client` package.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id        String   @id @default(cuid())
  title     String
  body      String?
  createdAt DateTime @default(now())

  // Most listings sort by recency; index supports ORDER BY createdAt.
  @@index([createdAt])
}
