// Prisma schema for the full-stack template.
// `Item` is a neutral example model — replace or delete it for your domain.
// Prisma 7 no longer carries the connection URL in the datasource block: the
// runtime connection comes from the PrismaPg driver adapter (see
// src/server/db/prisma.ts) and Migrate reads it from prisma.config.ts.

// Keep the legacy `prisma-client-js` generator so the bare `@prisma/client`
// import surface stays intact for prisma/seed.ts and src/server/services.
// Prisma 7's `prisma-client` generator requires a custom `output` path and a
// different import specifier, which would break those imports; preserving this
// generator is the smallest safe, Prisma 7-supported choice.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id        String   @id @default(cuid())
  title     String
  body      String?
  createdAt DateTime @default(now())

  // Most listings sort by recency; index supports ORDER BY createdAt.
  @@index([createdAt])
}
